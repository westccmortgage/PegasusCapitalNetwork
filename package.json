    "qa:runtime": "QA_BASE_URL=https://pegasuslendersgroup.com node qa/runtime-audit.js",
    "qa:forms": "QA_BASE_URL=https://pegasuslendersgroup.com node qa/form-audit.js",
    "qa:auth": "QA_BASE_URL=https://pegasuslendersgroup.com node qa/auth-audit.js",
    "qa:mobile": "QA_BASE_URL=https://pegasuslendersgroup.com node qa/mobile-audit.js",
    "qa:intelligence": "node qa/intelligence-audit.js",
    "qa:partner": "node qa/partner-audit.js",
    "qa:mapper": "node qa/mapper-audit.js",
    "qa:acceptance": "node qa/acceptance-ca-partner.js",
    "qa:enrichment": "node qa/enrichment-outreach-audit.js",
    "qa:all": "npm run qa:links && npm run qa:runtime && npm run qa:auth && npm run qa:mobile"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
