{
  "name": "pegasus-v69-platform-rebuild",
  "version": "69.0.0",
  "description": "Pegasus Network — the operating system for structured real estate capital.",
  "private": true,
  "scripts": {
    "build": "npm install",
    "qa": "node qa/link-audit.js && echo 'Run npm run qa:runtime for browser tests'",
